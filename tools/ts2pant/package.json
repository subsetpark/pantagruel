    "lint:fix": "biome check --write src"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "typescript": "^5.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/node": "^20.0.0",
    "vitest": "^3.0.0"
  }
}
