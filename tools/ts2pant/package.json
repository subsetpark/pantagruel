{
  "name": "ts2pant",
  "version": "0.1.0",
  "description": "Translate TypeScript functions into checkable Pantagruel specifications",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ts2pant": "dist/index.js"
  },
  "scripts": {
    "build:wasm": "node scripts/build-wasm.mjs",
    "build": "npm run build:wasm && tsc",
    "start": "node dist/index.js",
    "test": "npx tsx --test tests/*.test.mts",
    "test:update-snapshots": "npx tsx --test --test-update-snapshots tests/*.test.mts",
    "lint": "biome check src",
    "lint:fix": "biome check --write src"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "ts-morph": "^27.0.0",
    "typescript": "^5.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/node": "^20.0.0",
    "effect": "^3.21.0",
    "tsx": "^4.21.0"
  }
}
