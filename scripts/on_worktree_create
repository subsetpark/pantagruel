#!/bin/bash
set -euo pipefail

cd "$ONTON_WORKTREE_PATH"

# Ensure opam environment is available.
# Worktrees share a single global opam switch — do NOT create per-worktree
# switches (each is ~2GB). If no switch is set, select an existing one.
# If opam has never been initialized on this machine, fail loudly — switch
# creation takes 10+ minutes and should be done manually.
if ! opam switch show >/dev/null 2>&1; then
  switch=$(opam switch list --short 2>/dev/null | head -1)
  if [ -n "$switch" ]; then
    echo "No active opam switch. Selecting '$switch'..."
    opam switch "$switch"
  else
    echo "ERROR: No opam switches found. Run 'opam init -y && opam switch create default 5.4.1' manually."
    exit 1
  fi
fi
eval "$(opam env)"

# OCaml: build the project
opam exec -- dune build

# ts2pant: install node dependencies and build wasm assets
cd tools/ts2pant
npm install --silent
opam exec -- npm run build:wasm
