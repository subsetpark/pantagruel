#!/bin/bash
set -euo pipefail

cd "$ONTON_WORKTREE_PATH"

# Ensure opam environment is available.
# The main repo has a local opam switch (created with `opam switch create .`).
# Worktrees must use that switch — do NOT create per-worktree switches (each
# is ~2GB). We find the main repo root via git and point opam at its switch.
main_repo=$(dirname "$(git -C "$ONTON_WORKTREE_PATH" rev-parse --path-format=absolute --git-common-dir)")
if opam switch list --short 2>/dev/null | grep -qx "$main_repo"; then
  echo "Using opam switch at '$main_repo'..."
  eval "$(opam env --switch="$main_repo" --set-switch)"
else
  echo "ERROR: No opam switch found at '$main_repo'. Run 'opam switch create . 5.4.1' from the main repo."
  exit 1
fi

# OCaml: build the project
opam exec -- dune build

# ts2pant: install node dependencies and build wasm assets
cd tools/ts2pant
npm install --silent
opam exec -- npm run build:wasm
