{
  "module": "ADVANCED",
  "imports": [],
  "contexts": [],
  "types": {
    "Handle": { "kind": "domain" },
    "Item": { "kind": "domain" },
    "Key": { "kind": "domain" },
    "Value": { "kind": "domain" }
  },
  "rules": {
    "available": { "params": [ "Item" ], "return": "Bool" },
    "default-value": { "params": [], "return": "Value" },
    "mapping": { "params": [ "Key" ], "return": "Value" },
    "store": { "params": [ "Handle", "Key" ], "return": "Value" }
  },
  "chapters": [
    {
      "head": [
        {
          "doc": [ [ "Advanced features: overrides, qualified names" ] ],
          "kind": "domain",
          "name": "Key"
        },
        { "kind": "domain", "name": "Value" },
        {
          "kind": "rule",
          "name": "mapping",
          "params": [ { "name": "k", "type": "Key" } ],
          "guards": [],
          "return": "Value",
          "resolved": { "func": { "params": [ "Key" ], "return": "Value" } }
        },
        {
          "kind": "rule",
          "name": "default-value",
          "params": [],
          "guards": [],
          "return": "Value",
          "resolved": { "func": { "params": [], "return": "Value" } }
        },
        {
          "doc": [
            [
              "N-ary override: map-valued rule keyed by an owner handle and a key.",
              "Override key is a tuple whose arity matches the rule's parameter list."
            ]
          ],
          "kind": "domain",
          "name": "Handle"
        },
        {
          "kind": "rule",
          "name": "store",
          "params": [
            { "name": "h", "type": "Handle" }, { "name": "k", "type": "Key" }
          ],
          "guards": [],
          "return": "Value",
          "resolved": {
            "func": { "params": [ "Handle", "Key" ], "return": "Value" }
          }
        }
      ],
      "body": [
        {
          "doc": [
            [
              "Function override syntax: f[k |-> v]",
              "Creates a function like f but with f(k) = v"
            ],
            [ "Override with single mapping" ]
          ],
          "expr": {
            "forall": {
              "params": [
                { "name": "k", "type": "Key" },
                { "name": "v", "type": "Value" }
              ],
              "guards": [],
              "body": {
                "binop": {
                  "op": "eq",
                  "left": {
                    "app": {
                      "func": {
                        "override": {
                          "func": "mapping",
                          "mappings": [
                            {
                              "key": { "var": "k" },
                              "value": { "var": "v" }
                            }
                          ]
                        }
                      },
                      "args": [ { "var": "k" } ]
                    }
                  },
                  "right": { "var": "v" }
                }
              }
            }
          }
        },
        {
          "doc": [ [ "Override preserves other values" ] ],
          "expr": {
            "forall": {
              "params": [
                { "name": "k1", "type": "Key" },
                { "name": "k2", "type": "Key" },
                { "name": "v", "type": "Value" }
              ],
              "guards": [],
              "body": {
                "binop": {
                  "op": "impl",
                  "left": {
                    "binop": {
                      "op": "neq",
                      "left": { "var": "k1" },
                      "right": { "var": "k2" }
                    }
                  },
                  "right": {
                    "binop": {
                      "op": "eq",
                      "left": {
                        "app": {
                          "func": {
                            "override": {
                              "func": "mapping",
                              "mappings": [
                                {
                                  "key": { "var": "k1" },
                                  "value": { "var": "v" }
                                }
                              ]
                            }
                          },
                          "args": [ { "var": "k2" } ]
                        }
                      },
                      "right": {
                        "app": {
                          "func": { "var": "mapping" },
                          "args": [ { "var": "k2" } ]
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        {
          "doc": [ [ "Override doesn't affect other keys" ] ],
          "expr": {
            "forall": {
              "params": [
                { "name": "k1", "type": "Key" },
                { "name": "k2", "type": "Key" },
                { "name": "v", "type": "Value" }
              ],
              "guards": [],
              "body": {
                "binop": {
                  "op": "impl",
                  "left": {
                    "binop": {
                      "op": "neq",
                      "left": { "var": "k1" },
                      "right": { "var": "k2" }
                    }
                  },
                  "right": {
                    "binop": {
                      "op": "eq",
                      "left": {
                        "app": {
                          "func": {
                            "override": {
                              "func": "mapping",
                              "mappings": [
                                {
                                  "key": { "var": "k1" },
                                  "value": { "var": "v" }
                                }
                              ]
                            }
                          },
                          "args": [ { "var": "k2" } ]
                        }
                      },
                      "right": {
                        "app": {
                          "func": { "var": "mapping" },
                          "args": [ { "var": "k2" } ]
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        {
          "doc": [
            [
              "N-ary override with a tuple key: the override binds the combined position",
              "(h, k) and leaves every other (h', k') untouched."
            ]
          ],
          "expr": {
            "forall": {
              "params": [
                { "name": "h", "type": "Handle" },
                { "name": "k", "type": "Key" },
                { "name": "v", "type": "Value" }
              ],
              "guards": [],
              "body": {
                "binop": {
                  "op": "eq",
                  "left": {
                    "app": {
                      "func": {
                        "override": {
                          "func": "store",
                          "mappings": [
                            {
                              "key": {
                                "tuple": [ { "var": "h" }, { "var": "k" } ]
                              },
                              "value": { "var": "v" }
                            }
                          ]
                        }
                      },
                      "args": [ { "var": "h" }, { "var": "k" } ]
                    }
                  },
                  "right": { "var": "v" }
                }
              }
            }
          }
        },
        {
          "forall": {
            "params": [
              { "name": "h1", "type": "Handle" },
              { "name": "h2", "type": "Handle" },
              { "name": "k1", "type": "Key" },
              { "name": "k2", "type": "Key" },
              { "name": "v", "type": "Value" }
            ],
            "guards": [],
            "body": {
              "binop": {
                "op": "impl",
                "left": {
                  "binop": {
                    "op": "or",
                    "left": {
                      "binop": {
                        "op": "neq",
                        "left": { "var": "h1" },
                        "right": { "var": "h2" }
                      }
                    },
                    "right": {
                      "binop": {
                        "op": "neq",
                        "left": { "var": "k1" },
                        "right": { "var": "k2" }
                      }
                    }
                  }
                },
                "right": {
                  "binop": {
                    "op": "eq",
                    "left": {
                      "app": {
                        "func": {
                          "override": {
                            "func": "store",
                            "mappings": [
                              {
                                "key": {
                                  "tuple": [
                                    { "var": "h1" }, { "var": "k1" }
                                  ]
                                },
                                "value": { "var": "v" }
                              }
                            ]
                          }
                        },
                        "args": [ { "var": "h2" }, { "var": "k2" } ]
                      }
                    },
                    "right": {
                      "app": {
                        "func": { "var": "store" },
                        "args": [ { "var": "h2" }, { "var": "k2" } ]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      ]
    },
    {
      "head": [
        { "kind": "domain", "name": "Item" },
        {
          "kind": "rule",
          "name": "available",
          "params": [ { "name": "i", "type": "Item" } ],
          "guards": [],
          "return": "Bool",
          "resolved": { "func": { "params": [ "Item" ], "return": "Bool" } }
        }
      ],
      "body": [
        {
          "forall": {
            "params": [ { "name": "i", "type": "Item" } ],
            "guards": [],
            "body": {
              "binop": {
                "op": "or",
                "left": {
                  "app": {
                    "func": { "var": "available" },
                    "args": [ { "var": "i" } ]
                  }
                },
                "right": {
                  "unop": {
                    "op": "not",
                    "arg": {
                      "app": {
                        "func": { "var": "available" },
                        "args": [ { "var": "i" } ]
                      }
                    }
                  }
                }
              }
            }
          }
        },
        {
          "doc": [ [ "Negation mixed with implication and conjunction" ] ],
          "expr": {
            "forall": {
              "params": [ { "name": "i", "type": "Item" } ],
              "guards": [],
              "body": {
                "binop": {
                  "op": "impl",
                  "left": {
                    "unop": {
                      "op": "not",
                      "arg": {
                        "app": {
                          "func": { "var": "available" },
                          "args": [ { "var": "i" } ]
                        }
                      }
                    }
                  },
                  "right": {
                    "binop": {
                      "op": "and",
                      "left": { "bool": false },
                      "right": {
                        "app": {
                          "func": { "var": "available" },
                          "args": [ { "var": "i" } ]
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        {
          "doc": [ [ "Implication" ] ],
          "expr": {
            "forall": {
              "params": [ { "name": "i", "type": "Item" } ],
              "guards": [],
              "body": {
                "binop": {
                  "op": "impl",
                  "left": { "bool": false },
                  "right": {
                    "app": {
                      "func": { "var": "available" },
                      "args": [ { "var": "i" } ]
                    }
                  }
                }
              }
            }
          }
        },
        {
          "doc": [ [ "Membership" ] ],
          "expr": {
            "forall": {
              "params": [ { "name": "i", "type": "Item" } ],
              "guards": [],
              "body": {
                "binop": {
                  "op": "in",
                  "left": { "var": "i" },
                  "right": { "domain": "Item" }
                }
              }
            }
          }
        }
      ]
    }
  ]
}
