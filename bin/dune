(executable
 (name main)
 (public_name pant)
 (package pantagruel)
 (libraries pantagruel))

; Stamp the version from `git describe` at build time into a generated
; [Version] module, so `pant --version` tracks the release tags without a
; hand-maintained literal. [(universe)] makes the rule re-run each build (so a
; new tag/commit is picked up); falls back to "dev" outside a git checkout
; (e.g. an opam tarball), where git is unavailable. Mirrors onton/bin/dune.

(rule
 (target version.ml)
 (deps (universe))
 (action
  (with-stdout-to
   %{target}
   (bash
    "printf '(* Auto-generated by dune — do not edit *)\\nlet s = \"%s\"\\n' \"$(git describe --tags --always 2>/dev/null || echo dev)\""))))
